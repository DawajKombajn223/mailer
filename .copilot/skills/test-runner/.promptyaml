name: test-runner
description: Automatyczne uruchamianie i monitorowanie testów
applyTo:
  - path: "**/tests/**"
  - path: "test_*.py"
topics:
  - testing
  - pytest
  - coverage
  - automation
languageDetection:
  preferredLanguage: python
  patterns:
    - pytest
    - def test_
    - @pytest.fixture
